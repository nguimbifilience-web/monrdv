# ==============================================================================
# Configuration de l'application
# ==============================================================================
APP_NAME=MonRDV
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Langue par defaut de l'application (changer en 'fr' pour le francais)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Mode de maintenance : 'file' ou 'cache'
APP_MAINTENANCE_DRIVER=file

# Nombre de tours pour le hachage bcrypt (12 recommande en production)
BCRYPT_ROUNDS=12

# ==============================================================================
# Journalisation (Logs)
# ==============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==============================================================================
# Base de donnees
# ==============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=monrdv
DB_USERNAME=root
DB_PASSWORD=

# ==============================================================================
# Sessions et cache
# Sans Redis : SESSION_DRIVER=file, CACHE_STORE=file, QUEUE_CONNECTION=database
# Avec Redis : SESSION_DRIVER=redis, CACHE_STORE=redis, QUEUE_CONNECTION=redis
# ==============================================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
# En production HTTPS, activer :
#   SESSION_SECURE_COOKIE=true
#   SESSION_HTTP_ONLY=true
#   SESSION_SAME_SITE=lax
# En production derriere un reverse proxy (ex: InfinityFree, Cloudflare) :
#   FORCE_HTTPS=true
#   TRUSTED_PROXIES=* (ou liste d'IPs si connues)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=file

# ==============================================================================
# Redis (optionnel — decommenter si Redis est disponible sur votre hebergement)
# ==============================================================================
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ==============================================================================
# CDN / Assets (decommenter et renseigner pour utiliser un CDN)
# ==============================================================================
# ASSET_URL=https://cdn.monrdv.ga

# ==============================================================================
# Configuration email (SMTP pour la production)
# ==============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@monrdv.ga"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# Stockage AWS S3 (pour le stockage de fichiers dans le cloud)
# ==============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=

# ==============================================================================
# Octane (serveur haute performance)
# ==============================================================================
OCTANE_SERVER=roadrunner

# ==============================================================================
# Vite (assets front-end)
# ==============================================================================
VITE_APP_NAME="${APP_NAME}"
